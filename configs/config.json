{
  "builder": {
    "normalize": {
      "checkpoint_every": 200
    },
    "structure": {
      "checkpoint_every": 1000
    },
    "detect": {
      "document_workers": 0,
      "checkpoint_every": 400,
      "profiling": {
        "enabled": true
      }
    },
    "classify": {
      "checkpoint_every": 400,
      "interprets_filter_policy": {
        "high_confidence_true_threshold": 0.8,
        "low_confidence_false_threshold": 0.35,
        "use_llm_for_uncertain": true,
        "prediction_batch_size": 128
      },
      "llm_conflict": {
        "provider": "bigmodel",
        "model": "glm-4.5-air",
        "batch_size": 4,
        "concurrent_requests": 4,
        "request_timeout_seconds": 90,
        "max_retries": 2,
        "rate_limit": {
          "rpm": 0,
          "tpm": 0,
          "retry_count": 3,
          "backoff_seconds": 5
        },
        "params": {
          "temperature": 0.0,
          "max_tokens": 512
        }
      }
    },
    "extract": {
      "checkpoint_every": 20,
      "llm_extract": {
        "provider": "bigmodel",
        "model": "glm-4.5-air",
        "batch_size": 4,
        "concurrent_requests": 5,
        "request_timeout_seconds": 90,
        "max_retries": 2,
        "rate_limit": {
          "rpm": 0,
          "tpm": 0,
          "retry_count": 3,
          "backoff_seconds": 5
        },
        "params": {
          "temperature": 0.1,
          "max_tokens": 4096
        }
      }
    },
    "aggregate": {
      "checkpoint_every": 20,
      "llm_aggregate": {
        "provider": "siliconflow",
        "model": "Pro/deepseek-ai/DeepSeek-V3.2",
        "batch_size": 4,
        "concurrent_requests": 5,
        "request_timeout_seconds": 90,
        "max_retries": 2,
        "rate_limit": {
          "rpm": 0,
          "tpm": 0,
          "retry_count": 3,
          "backoff_seconds": 5
        },
        "params": {
          "temperature": 0.0,
          "max_tokens": 4096
        }
      }
    },
    "align": {
      "checkpoint_every": 20,
      "embed": {
        "checkpoint_every": 200,
        "provider": "siliconflow",
        "model": "BAAI/bge-m3",
        "batch_size": 32,
        "concurrent_requests": 4,
        "request_timeout_seconds": 90,
        "max_retries": 2,
        "rate_limit": {
          "rpm": 0,
          "tpm": 0,
          "retry_count": 3,
          "backoff_seconds": 5
        },
        "params": {}
      },
      "recall": {
        "checkpoint_every": 1000,
        "top_k_per_concept": 20,
        "similarity_threshold": 0.85,
        "matrix_block_size": 512
      },
      "judge": {
        "provider": "bigmodel",
        "model": "glm-4.5-air",
        "checkpoint_every": 100,
        "batch_size": 25,
        "concurrent_requests": 4,
        "request_timeout_seconds": 90,
        "max_retries": 2,
        "rate_limit": {
          "rpm": 0,
          "tpm": 0,
          "retry_count": 3,
          "backoff_seconds": 5
        },
        "params": {
          "temperature": 0.0,
          "max_tokens": 512
        }
      }
    }
  },
  "interprets_filter": {
    "dataset": {
      "max_samples": 1500,
      "label_weights": {
        "true": 0.5,
        "false": 0.5
      },
      "candidate_pool_multiplier": 12.0,
      "candidate_pool_minimum": 1200,
      "adaptive_sampling": {
        "enabled": true,
        "oversample_factor": 5.0,
        "min_positive_hint_precision": 0.15,
        "min_negative_hint_precision": 0.85,
        "max_in_flight_batches": 4
      },
      "splits": {
        "train": 0.8,
        "dev": 0.1,
        "test": 0.1
      },
      "random_seed": 42,
      "review_sample_size": 20
    },
    "distill": {
      "provider": "bigmodel",
      "model": "glm-4.7",
      "concurrent_requests": 4,
      "batch_size": 4,
      "request_timeout_seconds": 90,
      "max_retries": 2,
      "rate_limit": {
        "rpm": 0,
        "tpm": 0,
        "retry_count": 3,
        "backoff_seconds": 5
      },
      "params": {
        "temperature": 0.0,
        "max_tokens": 512
      }
    },
    "train": {
      "backbone_model": "hfl/chinese-roberta-wwm-ext",
      "device_preference": "cuda",
      "mixed_precision": "auto",
      "max_length": 512,
      "num_train_epochs": 1,
      "learning_rate": 2e-05,
      "train_batch_size": 4,
      "eval_batch_size": 8,
      "weight_decay": 0.01,
      "warmup_ratio": 0.1,
      "seed": 42,
      "logging_steps": 10,
      "save_total_limit": 1,
      "dataloader_pin_memory": true,
      "dataloader_num_workers": 2,
      "target_recall": 0.9,
      "target_precision": 0.85,
      "threshold_selection_mode": "precision_first",
      "threshold_grid": [
        0.25,
        0.3,
        0.35,
        0.4,
        0.45,
        0.5,
        0.55,
        0.6
      ]
    },
    "predict": {
      "default_model_dir": "models/interprets_filter",
      "max_length": 512,
      "threshold": 0.5
    },
    "hub": {
      "model_repo_id": "Ruiyang-Zh/interprets-filter",
      "model_revision": "main",
      "dataset_repo_id": "Ruiyang-Zh/interprets-filter",
      "dataset_revision": "main"
    }
  }
}
