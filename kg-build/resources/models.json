{
  "summarize": {
    "provider": "openai_compatible",
    "purpose": "summarize",
    "model": "glm-4-air",
    "base_url_env": "OPENAI_BASE_URL_SUMMARIZE",
    "api_key_env": "OPENAI_API_KEY_SUMMARIZE",
    "model_env": "OPENAI_MODEL_SUMMARIZE",
    "params": {
      "temperature": 0.2,
      "max_tokens": 256,
      "timeout_seconds": 60,
      "max_retries": 2
    }
  },
